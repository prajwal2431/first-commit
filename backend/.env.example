# Server
PORT=3000

# MongoDB (required for backend)
MONGODB_URI=mongodb://localhost:27017/decision-intelligence

# Optional: tenant id for npm run seed:sample (must match JWT tenant after login)
# TENANT_ID=default

# AWS (for Bedrock / RCAagent)
# AWS_REGION=eu-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# RCAagent (Bedrock AgentCore runtime)
# RCA_AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:eu-west-2:123456789012:runtime/your-rca-runtime-id
# RCA_AGENT_RUNTIME_QUALIFIER=DEV
# RCA_AGENT_REGION=eu-west-2
# RCA_AGENT_TIMEOUT_MS=30000

# Feature flag: set to "false" to disable RCAagent for chat and use legacy template responder
# USE_RCA_AGENT_FOR_CHAT=true
